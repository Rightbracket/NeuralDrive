[Unit]
Description=NeuralDrive Ollama Service
After=network.target neuraldrive-gpu-detect.service
Requires=neuraldrive-gpu-detect.service

[Service]
Environment=HOME=/var/lib/neuraldrive
EnvironmentFile=/etc/neuraldrive/ollama.conf
ExecStartPre=/usr/bin/mkdir -p /var/lib/neuraldrive/models
ExecStart=/usr/local/bin/ollama serve
User=neuraldrive-ollama
Group=neuraldrive-ollama
SupplementaryGroups=video render
Restart=always
RestartSec=5
KillMode=process

LimitNOFILE=65535
MemoryHigh=90%
MemoryMax=95%

ProtectSystem=full
ProtectHome=yes
NoNewPrivileges=yes
PrivateTmp=yes
PrivateDevices=no
ProtectKernelTunables=yes
ProtectControlGroups=yes
DeviceAllow=/dev/nvidia* rw
DeviceAllow=/dev/dri/* rw
ReadWritePaths=/var/lib/neuraldrive /var/log/neuraldrive /etc/neuraldrive /run/neuraldrive

[Install]
WantedBy=multi-user.target
